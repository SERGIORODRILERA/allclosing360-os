# ─── Required ──────────────────────────────────────────────────────────────────
# Claude API — server-side only, never exposed to the client bundle
ANTHROPIC_API_KEY=sk-ant-...

# ─── GitHub integration (Director de Producto) ─────────────────────────────────
# Personal access token with: repo (read + write), pull_requests
GITHUB_TOKEN=ghp_...

# Repository in "owner/repo" format, e.g. SERGIORODRILERA/allclosing360
GITHUB_REPO=SERGIORODRILERA/allclosing360

# ─── Optional ──────────────────────────────────────────────────────────────────
# Set on Vercel under Project → Settings → Environment Variables
# Never commit real values — this file is for documentation only
