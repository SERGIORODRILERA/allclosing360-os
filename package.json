{
  "name": "allclosing360-os",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\" --ignore-path .gitignore",
    "infra:up": "docker compose -f infrastructure/docker/compose/docker-compose.infra.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker/compose/docker-compose.infra.yml down",
    "infra:logs": "docker compose -f infrastructure/docker/compose/docker-compose.infra.yml logs -f"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@types/node": "^20.14.0",
    "playwright": "^1.60.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.9",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
