# ============================================================
# ALLCLOSING360 OS — Environment Variables
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# --- Infrastructure ---
DATABASE_URL=postgresql://ac360:ac360dev@localhost:5432/ac360_dev
DATABASE_URL_READ=postgresql://ac360:ac360dev@localhost:5432/ac360_dev
REDIS_URL=redis://:ac360dev@localhost:6379
NATS_URL=nats://localhost:4222

# --- Platform ---
NODE_ENV=development
PORT=3000
API_GATEWAY_PORT=4000

# --- Auth ---
JWT_SECRET=change-me-min-32-chars-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# OAuth providers (optional in dev)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# --- Billing ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Notifications ---
RESEND_API_KEY=re_...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# --- AI Providers ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# --- Voice ---
VAPI_API_KEY=
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# --- Advertising Integrations ---
META_ADS_APP_ID=
META_ADS_APP_SECRET=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Storage ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ac360-dev-storage

# --- Observability ---
SENTRY_DSN=
GRAFANA_API_KEY=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
